<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_maintenance" model="ir.ui.view">
        <field name="name">res.partner.form.maintenance</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Mantenimiento" name="maintenance">
                    <field name="maintenance_contract_ids">
                        <tree editable="bottom" string="Contratos de mantenimiento">
                            <field name="name" placeholder="Ej: Compresor A, Caldera principal…"/>
                            <field name="contract_date"/>
                            <field name="maintenance_interval"/>
                            <field name="maintenance_responsible_id"/>
                            <field name="maintenance_active"/>
                            <field name="last_maintenance_date"/>
                            <field name="next_maintenance_date" readonly="1"/>
                            <button
                                name="action_register_maintenance"
                                type="object"
                                string="Registrar hoy"
                                icon="fa-check"
                                confirm="¿Confirmar que el mantenimiento de este equipo fue realizado hoy?"
                            />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
